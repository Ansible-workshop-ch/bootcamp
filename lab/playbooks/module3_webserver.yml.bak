---
# Module 3: a basic, readable playbook combining install + service.
- name: Module 3 - basic web server setup
  hosts: web
  become: true

  tasks:
    - name: Install httpd
      ansible.builtin.package:
        name: httpd
        state: present

    - name: Start and enable httpd
      ansible.builtin.service:
        name: httpd
        state: started
        enabled: true
